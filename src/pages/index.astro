                <div class="w-full bg-white/5 h-1.5 rounded-full overflow-hidden border border-white/5">
                  <div class={`h-full rounded-full ${skill.barColor}`} style={`width: ${skill.percentage}%`}></div>
                </div>
              </div>

              <!-- Last used metadata -->
              <div class="pt-2.5 border-t border-white/5 flex items-center justify-between text-[9px] text-text-muted font-sans">
                <span>Último uso:</span>
                <span class="font-medium text-white/80 truncate max-w-[150px]">{skill.lastUsed}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CONTACTO SECTION -->
    <section id="contact" class="py-24 px-4 max-w-4xl mx-auto relative">
      <div class="text-center max-w-2xl mx-auto mb-16 space-y-4">
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white">
          Iniciemos un Proyecto
        </h2>
        <p class="text-text-muted">
          ¿Tienes una idea en mente o buscas un perfil Frontend Senior? Escríbeme y charlemos.
        </p>
      </div>

      <!-- Glassmorphic Form -->
      <div class="glass-panel p-6 sm:p-10 rounded-3xl relative overflow-hidden shadow-2xl">
        <!-- Glow accents inside -->
        <div class="absolute -top-32 -left-32 w-64 h-64 bg-primary/10 rounded-full blur-[60px] pointer-events-none"></div>
        <div class="absolute -bottom-32 -right-32 w-64 h-64 bg-accent/10 rounded-full blur-[60px] pointer-events-none"></div>

        <form id="contact-form" class="space-y-6 relative z-10">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="name" class="text-xs font-semibold uppercase tracking-wider text-text-muted">Nombre</label>
              <input 
                type="text" 
                id="name" 
                required 
                placeholder="Juan Pérez" 
                class="w-full px-4 py-3 bg-bg-dark/50 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-accent transition-colors duration-300"
              />
              <span id="error-name" class="text-xs text-[#ff5f56] hidden">El nombre es requerido.</span>
            </div>
            
            <div class="space-y-2">
              <label for="email" class="text-xs font-semibold uppercase tracking-wider text-text-muted">Correo Electrónico</label>
              <input 
                type="email" 
                id="email" 
                required 
                placeholder="juan@ejemplo.com" 
                class="w-full px-4 py-3 bg-bg-dark/50 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-accent transition-colors duration-300"
              />
              <span id="error-email" class="text-xs text-[#ff5f56] hidden">Ingresa un correo electrónico válido.</span>
            </div>
          </div>

          <div class="space-y-2">
            <label for="subject" class="text-xs font-semibold uppercase tracking-wider text-text-muted">Asunto</label>
            <input 
              type="text" 
              id="subject" 
              required 
              placeholder="Oportunidad laboral / Propuesta de proyecto" 
              class="w-full px-4 py-3 bg-bg-dark/50 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-accent transition-colors duration-300"
            />
            <span id="error-subject" class="text-xs text-[#ff5f56] hidden">El asunto es requerido.</span>
          </div>

          <div class="space-y-2">
            <label for="message" class="text-xs font-semibold uppercase tracking-wider text-text-muted">Mensaje</label>
            <textarea 
              id="message" 
              required 
              rows="5" 
              placeholder="Hola César, me gustaría hablar contigo sobre..." 
              class="w-full px-4 py-3 bg-bg-dark/50 border border-white/10 rounded-xl text-white placeholder-white/30 focus:outline-none focus:border-accent transition-colors duration-300 resize-none"
            ></textarea>
            <span id="error-message" class="text-xs text-[#ff5f56] hidden">El mensaje es requerido.</span>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="w-full py-4 rounded-xl bg-gradient-to-r from-primary to-secondary hover:shadow-[0_0_25px_rgba(109,94,249,0.5)] text-white font-bold text-sm tracking-wide uppercase transition-all duration-300 transform hover:-translate-y-0.5 border border-primary/20 hover:border-accent flex items-center justify-center gap-2 cursor-pointer"
          >
            <span>Enviar Mensaje</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4">
              <path d="M22 2L11 13M22 2L15 22L11 13M11 13L2 9L22 2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </form>

        <!-- Success Toast -->
        <div id="form-success" class="absolute inset-0 z-20 bg-bg-dark/95 flex flex-col items-center justify-center text-center p-6 space-y-4 opacity-0 pointer-events-none transition-all duration-300">
          <div class="w-16 h-16 rounded-full bg-[#27c93f]/15 border border-[#27c93f]/30 flex items-center justify-center text-[#27c93f] text-3xl font-bold animate-bounce">
            ✓
          </div>
          <h3 class="text-xl font-display font-bold text-white">¡Mensaje Enviado Exitosamente!</h3>
          <p class="text-text-muted text-sm max-w-sm">Gracias por ponerte en contacto. Te responderé lo antes posible para concretar detalles.</p>
          <button id="reset-form" class="px-6 py-2 rounded-full border border-white/10 hover:border-accent/40 text-xs font-semibold text-text-muted hover:text-white transition-colors duration-300 cursor-pointer">Enviar otro mensaje</button>
        </div>
      </div>
    </section>

    <!-- Global Lightbox Modal -->
    <div id="global-lightbox" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-bg-dark/95 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
      <div class="max-w-4xl w-full flex flex-col items-center justify-center relative scale-95 transition-transform duration-300" id="lightbox-container">
        <button id="close-lightbox" class="absolute -top-12 right-0 text-text-muted hover:text-white text-4xl font-bold cursor-pointer bg-transparent border-0" aria-label="Cerrar modal">&times;</button>
        <div class="relative w-full border border-white/10 rounded-2xl overflow-hidden shadow-2xl bg-card-dark flex items-center justify-center">
          <img id="lightbox-img" src="" alt="" class="max-h-[75vh] w-auto max-w-full object-contain" />
        </div>
        <p id="lightbox-caption" class="text-white font-display mt-4 font-semibold text-center text-sm sm:text-base"></p>
        <a href="" id="lightbox-download" download class="mt-4 px-6 py-2.5 rounded-full bg-primary hover:bg-primary/80 border border-primary/20 text-white text-xs font-bold uppercase tracking-wider transition-all duration-300" target="_blank">Descargar / Ver original</a>
      </div>
    </div>

    <!-- Project Detailed Modal -->
    <div id="project-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-bg-dark/95 backdrop-blur-md opacity-0 pointer-events-none transition-all duration-300">
      <div class="w-full max-w-2xl glass-panel rounded-3xl p-6 sm:p-8 relative shadow-2xl scale-95 transition-transform duration-300 overflow-y-auto max-h-[90vh] bg-card-dark border border-white/10" id="project-modal-container">
        <button id="close-project-modal" class="absolute top-4 right-4 text-text-muted hover:text-white text-3xl font-bold cursor-pointer bg-transparent border-0 outline-none" aria-label="Cerrar modal">&times;</button>
        
        <div class="space-y-6 text-left">
          <!-- Project Image -->
          <div class="relative w-full aspect-video rounded-2xl overflow-hidden border border-white/10 bg-bg-dark flex items-center justify-center shadow-inner">
            <img id="pm-image" src="" alt="" class="w-full h-full object-cover" />
          </div>
          
          <div>
            <h3 id="pm-title" class="text-2xl sm:text-3xl font-display font-bold text-white"></h3>
            <p id="pm-short-desc" class="text-accent text-sm font-semibold mt-1 font-sans"></p>
          </div>
          
          <!-- Description -->
          <div class="space-y-2">
            <h4 class="text-xs font-display font-bold text-white uppercase tracking-wider border-b border-white/5 pb-1">Sobre el proyecto</h4>
            <p id="pm-desc" class="text-text-muted text-sm font-sans leading-relaxed"></p>
          </div>
          
          <!-- Technologies -->
          <div class="space-y-2">
            <h4 class="text-xs font-display font-bold text-white uppercase tracking-wider border-b border-white/5 pb-1">Tecnologías Utilizadas</h4>
            <div id="pm-techs" class="flex flex-wrap gap-2 pt-1"></div>
          </div>
          
          <!-- Participation -->
          <div class="space-y-2">
            <h4 class="text-xs font-display font-bold text-white uppercase tracking-wider border-b border-white/5 pb-1">Mi Participación</h4>
            <ul id="pm-participation" class="list-disc pl-5 text-text-muted text-sm space-y-2 font-sans pt-1"></ul>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initHeroCanvas() {
    const canvas = document.getElementById('hero-particles') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = canvas.width = window.innerWidth;
    let height = canvas.height = window.innerHeight;

    const particles: Array<{ x: number; y: number; vx: number; vy: number; radius: number; color: string }> = [];
    const particleCount = Math.min(100, Math.floor((width * height) / 15000)); // Responsive count

    // Palette matches our primary, secondary, and accent colors
    const colors = [
      'rgba(109, 94, 249, 0.4)', // Primary Glow
      'rgba(139, 92, 246, 0.4)', // Secondary Purple
      'rgba(0, 212, 255, 0.5)'   // Accent Cyan
    ];

    for (let i = 0; i < particleCount; i++) {
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.4,
        vy: (Math.random() - 0.5) * 0.4,
        radius: Math.random() * 2 + 1,
        color: colors[Math.floor(Math.random() * colors.length)]
      });
    }

    let mouseX = width / 2;
    let mouseY = height / 2;

    window.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
    });

    let animationFrameId: number;

    function animate() {
      ctx!.clearRect(0, 0, width, height);

      // Draw and update particles
      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;

        // Boundary collision
        if (p.x < 0 || p.x > width) p.vx *= -1;
        if (p.y < 0 || p.y > height) p.vy *= -1;

        // Attract lightly to mouse position
        const dx = mouseX - p.x;
        const dy = mouseY - p.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 180) {
          p.x += (dx / dist) * 0.3;
          p.y += (dy / dist) * 0.3;
        }

        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
        ctx!.fillStyle = p.color;
        ctx!.fill();
      });

      // Draw web links between close particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const pi = particles[i];
          const pj = particles[j];
          const dx = pi.x - pj.x;
          const dy = pi.y - pj.y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < 120) {
            ctx!.beginPath();
            ctx!.moveTo(pi.x, pi.y);
            ctx!.lineTo(pj.x, pj.y);
            ctx!.strokeStyle = `rgba(109, 94, 249, ${0.15 * (1 - dist / 120)})`;
            ctx!.lineWidth = 0.5;
            ctx!.stroke();
          }
        }
      }

      animationFrameId = requestAnimationFrame(animate);
    }

    animate();

    const handleResize = () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
    };

    window.addEventListener('resize', handleResize);

    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(animationFrameId);
      window.removeEventListener('resize', handleResize);
    }, { once: true });
  }

  function initStatsAnimation() {
    const numbers = document.querySelectorAll('.stat-number');
    if (numbers.length === 0) return;

    numbers.forEach((num) => {
      const target = parseInt(num.getAttribute('data-target') || '0', 10);
      
      gsap.fromTo(num, 
        { textContent: '0' },
        {
          textContent: target.toString(),
          duration: 2.5,
          ease: 'power2.out',
          snap: { textContent: 1 },
          scrollTrigger: {
            trigger: num,
            start: 'top 90%',
            toggleActions: 'play none none none'
          }
        }
      );
    });
  }

  function initScrollReveals() {
    // Experience timeline reveals
    const timelineItems = document.querySelectorAll('.timeline-item');
    timelineItems.forEach((item) => {
      gsap.from(item, {
        opacity: 0,
        x: -50,
        duration: 0.8,
        scrollTrigger: {
          trigger: item,
          start: 'top 80%',
          toggleActions: 'play none none none'
        }
      });
    });
  }

  function initTiltCards() {
    const cards = document.querySelectorAll('.tilt-card');
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const mouseEvent = e as MouseEvent;
        const rect = card.getBoundingClientRect();
        const x = mouseEvent.clientX - rect.left - rect.width / 2;
        const y = mouseEvent.clientY - rect.top - rect.height / 2;
        
        gsap.to(card, {
          rotateX: -y / 15,
          rotateY: x / 15,
          transformPerspective: 800,
          duration: 0.3,
          ease: 'power2.out',
          overwrite: 'auto'
        });
      });

      card.addEventListener('mouseleave', () => {
        gsap.to(card, {
          rotateX: 0,
          rotateY: 0,
          duration: 0.5,
          ease: 'power2.out',
          overwrite: 'auto'
        });
      });
    });
  }

  function initGlobalLightbox() {
    const triggers = document.querySelectorAll('.lightbox-trigger');
    const lightbox = document.getElementById('global-lightbox');
    const container = document.getElementById('lightbox-container');
    const img = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const caption = document.getElementById('lightbox-caption');
    const download = document.getElementById('lightbox-download') as HTMLAnchorElement | null;
    const closeBtn = document.getElementById('close-lightbox');

    if (!lightbox || !container || !img || !caption || !download || !closeBtn) return;

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const src = trigger.getAttribute('data-src') || '';
        const text = trigger.getAttribute('data-caption') || '';
        
        img.src = src;
        caption.textContent = text;
        download.href = src;

        lightbox.classList.remove('pointer-events-none');
        gsap.to(lightbox, { opacity: 1, duration: 0.3 });
        gsap.to(container, { scale: 1, duration: 0.3, ease: 'back.out(1.4)' });
        document.body.style.overflow = 'hidden';
      });
    });

    const hideLightbox = () => {
      gsap.to(container, { scale: 0.95, duration: 0.2 });
      gsap.to(lightbox, {
        opacity: 0,
        duration: 0.2,
        onComplete: () => {
          lightbox.classList.add('pointer-events-none');
          document.body.style.overflow = '';
        }
      });
    };

    closeBtn.addEventListener('click', hideLightbox);
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) hideLightbox();
    });
  }

  function initProjectModal() {
    const cards = document.querySelectorAll('.project-trigger-card');
    const modal = document.getElementById('project-modal');
    const container = document.getElementById('project-modal-container');
    const closeBtn = document.getElementById('close-project-modal');
    
    const pmImage = document.getElementById('pm-image') as HTMLImageElement | null;
    const pmTitle = document.getElementById('pm-title');
    const pmShortDesc = document.getElementById('pm-short-desc');
    const pmDesc = document.getElementById('pm-desc');
    const pmTechs = document.getElementById('pm-techs');
    const pmParticipation = document.getElementById('pm-participation');

    if (!modal || !closeBtn || !container) return;

    const openModal = (proj: any) => {
      if (pmImage) pmImage.src = proj.image;
      if (pmTitle) pmTitle.textContent = proj.title;
      if (pmShortDesc) pmShortDesc.textContent = proj.shortDesc;
      if (pmDesc) pmDesc.textContent = proj.desc;
      
      // Render Techs
      if (pmTechs) {
        pmTechs.innerHTML = '';
        proj.techs.forEach((tech: string) => {
          const span = document.createElement('span');
          span.className = 'px-3 py-1 rounded-md bg-white/5 border border-white/10 text-xs font-bold text-text-muted uppercase tracking-wider';
          span.textContent = tech;
          pmTechs.appendChild(span);
        });
      }

      // Render Participation
      if (pmParticipation) {
        pmParticipation.innerHTML = '';
        proj.participation.forEach((part: string) => {
          const li = document.createElement('li');
          li.textContent = part;
          pmParticipation.appendChild(li);
        });
      }

      modal.classList.remove('pointer-events-none');
      gsap.to(modal, { opacity: 1, duration: 0.3 });
      gsap.to(container, { scale: 1, duration: 0.3, ease: 'back.out(1.4)' });
      document.body.style.overflow = 'hidden';
    };

    const closeModal = () => {
      gsap.to(container, { scale: 0.95, duration: 0.2 });
      gsap.to(modal, {
        opacity: 0,
        duration: 0.2,
        onComplete: () => {
          modal.classList.add('pointer-events-none');
          document.body.style.overflow = '';
        }
      });
    };

    cards.forEach((card) => {
      card.addEventListener('click', (e) => {
        // Prevent trigger if clicking on button inside it since it already triggers the card click event
        const raw = card.getAttribute('data-project');
        if (!raw) return;
        const proj = JSON.parse(raw);
        openModal(proj);
      });
    });

    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  function initFormValidation() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const successToast = document.getElementById('form-success');
    const resetBtn = document.getElementById('reset-form');

    if (!form || !successToast || !resetBtn) return;

    const nameIn = document.getElementById('name') as HTMLInputElement;
    const emailIn = document.getElementById('email') as HTMLInputElement;
    const subjectIn = document.getElementById('subject') as HTMLInputElement;
    const messageIn = document.getElementById('message') as HTMLTextAreaElement;

    const errName = document.getElementById('error-name');
    const errEmail = document.getElementById('error-email');
    const errSubject = document.getElementById('error-subject');
    const errMessage = document.getElementById('error-message');

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      let hasError = false;

      // Validate Name
      if (!nameIn.value.trim()) {
        errName?.classList.remove('hidden');
        hasError = true;
      } else {
        errName?.classList.add('hidden');
      }

      // Validate Email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailIn.value.trim() || !emailRegex.test(emailIn.value)) {
        errEmail?.classList.remove('hidden');
        hasError = true;
      } else {
        errEmail?.classList.add('hidden');
      }

      // Validate Subject
      if (!subjectIn.value.trim()) {
        errSubject?.classList.remove('hidden');
        hasError = true;
      } else {
        errSubject?.classList.add('hidden');
      }

      // Validate Message
      if (!messageIn.value.trim()) {
        errMessage?.classList.remove('hidden');
        hasError = true;
      } else {
        errMessage?.classList.add('hidden');
      }

      if (!hasError) {
        // Obtener elementos de envío para cambiar el estado visual
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const btnSpan = submitBtn?.querySelector('span');
        const originalText = btnSpan ? btnSpan.textContent : 'Enviar Mensaje';

        if (submitBtn && btnSpan) {
          submitBtn.disabled = true;
          btnSpan.textContent = 'Enviando...';
        }

        // Estructurar el payload del correo
        const payload = {
          name: nameIn.value,
          email: emailIn.value,
          subject: subjectIn.value,
          message: messageIn.value
        };

        // Enviar la petición POST al endpoint de Astro
        fetch('/api/contact', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        })
        .then(async (response) => {
          const result = await response.json();
          if (response.ok) {
            // Mostrar la ventana de éxito de GSAP si todo salió bien
            successToast.classList.remove('pointer-events-none');
            gsap.to(successToast, { opacity: 1, duration: 0.4 });
          } else {
            // Mostrar error controlado del servidor
            alert(result.error || 'Ocurrió un error al enviar el formulario.');
          }
        })
        .catch((err) => {
          console.error('Error de red al enviar formulario:', err);
          alert('Ocurrió un error de red al intentar enviar el mensaje.');
        })
        .finally(() => {
          // Restaurar estado del botón de envío
          if (submitBtn && btnSpan) {
            submitBtn.disabled = false;
            btnSpan.textContent = originalText;
          }
        });
      }
    });

    resetBtn.addEventListener('click', () => {
      form.reset();
      gsap.to(successToast, {
        opacity: 0,
        duration: 0.4,
        onComplete: () => {
          successToast.classList.add('pointer-events-none');
        }
      });
    });
  }

  const setupPage = () => {
    initHeroCanvas();
    initStatsAnimation();
    initScrollReveals();
    initFormValidation();
    initTiltCards();
    initGlobalLightbox();
    initProjectModal();
  };

  document.addEventListener('astro:page-load', setupPage);

  document.addEventListener('astro:before-preparation', () => {
    ScrollTrigger.getAll().forEach(t => t.kill());
  });
</script>

<style>
  /* Custom filter highlight classes */
  .active-filter {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: white !important;
  }
  
  /* Scrollbar hide helper for carousels */
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
