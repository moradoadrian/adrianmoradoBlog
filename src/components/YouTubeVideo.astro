---
interface Props {
  videoId: string;
  title: string;
}

const { videoId, title } = Astro.props;
---

<div class="my-8 glass-card rounded-2xl overflow-hidden border border-white/10 max-w-3xl mx-auto shadow-xl">
  <!-- Responsive iframe aspect ratio -->
  <div class="relative w-full aspect-video">
    <iframe
      src={`https://www.youtube.com/embed/${videoId}`}
      title={title}
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
      class="absolute top-0 left-0 w-full h-full border-0"
    ></iframe>
  </div>
  <!-- Specific Disclaimer footer -->
  <div class="px-6 py-4 bg-bg-dark/80 text-xs text-text-muted flex flex-col sm:flex-row justify-between items-start sm:items-center gap-2 border-t border-white/5 select-none">
    <div>
      <span class="font-semibold text-white">Video:</span> {title}
    </div>
    <div class="text-[10px] text-accent font-medium italic">
      Este video pertenece a su creador original en YouTube y se muestra únicamente como recurso educativo.
    </div>
  </div>
</div>
