---
import { SITE_TITLE } from '../consts';
---

<header class="fixed top-0 left-0 w-full z-40 transition-all duration-300 px-4 py-4 md:px-8" id="main-header">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-6 py-3 rounded-full border border-white/10 bg-bg-dark/70 backdrop-blur-md transition-all duration-300 shadow-lg shadow-black/30" id="nav-container">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group text-xl font-bold font-display tracking-tight text-white select-none">
      <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent group-hover:animate-pulse">CM</span>
      <span class="text-white/40 group-hover:text-accent transition-colors duration-300">.dev</span>
    </a>

    <!-- Desktop Navigation Links -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="/#about" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Sobre Mí</a>
      <a href="/#skills" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Tecnologías</a>
      <a href="/#experience" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Experiencia</a>
      <a href="/#projects" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Proyectos</a>
      <a href="/blog" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Blog</a>
      <a href="/forum" class="text-text-muted hover:text-white transition-colors duration-200 py-1 relative after:content-[''] after:absolute after:bottom-0 after:left-0 after:w-full after:h-[2px] after:bg-accent after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:duration-300 after:origin-left">Foro</a>
      <a href="/#contact" class="px-5 py-2 rounded-full bg-primary hover:bg-primary/80 text-white font-semibold text-xs uppercase tracking-wider transition-all duration-300 hover:shadow-[0_0_15px_rgba(109,94,249,0.5)] border border-primary/20 hover:border-accent">Contacto</a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="md:hidden flex flex-col justify-center items-center w-8 h-8 text-white relative z-50 focus:outline-none" id="mobile-menu-btn" aria-label="Abrir menú">
      <span class="w-6 h-[2px] bg-white rounded transition-all duration-300 origin-center" id="menu-bar-1"></span>
      <span class="w-6 h-[2px] bg-white rounded transition-all duration-300 origin-center my-[5px]" id="menu-bar-2"></span>
      <span class="w-6 h-[2px] bg-white rounded transition-all duration-300 origin-center" id="menu-bar-3"></span>
    </button>
  </nav>

  <!-- Mobile Drawer Menu (Hidden by default) -->
  <div class="fixed inset-0 w-full h-screen bg-bg-dark/95 backdrop-blur-xl z-40 transform translate-x-full transition-transform duration-500 ease-out flex flex-col justify-center items-center gap-8 md:hidden" id="mobile-drawer">
    <a href="/#about" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Sobre Mí</a>
    <a href="/#skills" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Tecnologías</a>
    <a href="/#experience" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Experiencia</a>
    <a href="/#projects" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Proyectos</a>
    <a href="/blog" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Blog</a>
    <a href="/forum" class="mobile-nav-link text-2xl font-display font-medium text-text-muted hover:text-accent transition-colors duration-200">Foro</a>
    <a href="/#contact" class="mobile-nav-link px-8 py-3 rounded-full bg-gradient-to-r from-primary to-secondary text-white font-semibold text-sm uppercase tracking-wider transition-all duration-300 shadow-[0_0_20px_rgba(109,94,249,0.3)]">Contacto</a>
  </div>
</header>

<script>
  function setupHeader() {
    const header = document.getElementById('main-header');
    const navContainer = document.getElementById('nav-container');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const drawer = document.getElementById('mobile-drawer');
    const bar1 = document.getElementById('menu-bar-1');
    const bar2 = document.getElementById('menu-bar-2');
    const bar3 = document.getElementById('menu-bar-3');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');

    if (!header || !navContainer || !menuBtn || !drawer) return;

    // Scroll effect (shrink header on scroll)
    const handleScroll = () => {
      if (window.scrollY > 50) {
        header.classList.remove('py-4');
        header.classList.add('py-2');
        navContainer.classList.remove('bg-bg-dark/70');
        navContainer.classList.add('bg-bg-dark/90', 'shadow-2xl', 'border-white/20');
      } else {
        header.classList.remove('py-2');
        header.classList.add('py-4');
        navContainer.classList.remove('bg-bg-dark/90', 'shadow-2xl', 'border-white/20');
        navContainer.classList.add('bg-bg-dark/70');
      }
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // Initial check

    // Toggle menu
    let isMenuOpen = false;
    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      if (isMenuOpen) {
        // Open
        drawer.classList.remove('translate-x-full');
        bar1?.classList.add('rotate-45', 'translate-y-[7px]');
        bar2?.classList.add('opacity-0', 'scale-0');
        bar3?.classList.add('-rotate-45', '-translate-y-[7px]');
        document.body.style.overflow = 'hidden';
      } else {
        // Close
        drawer.classList.add('translate-x-full');
        bar1?.classList.remove('rotate-45', 'translate-y-[7px]');
        bar2?.classList.remove('opacity-0', 'scale-0');
        bar3?.classList.remove('-rotate-45', '-translate-y-[7px]');
        document.body.style.overflow = '';
      }
    };

    menuBtn.addEventListener('click', toggleMenu);

    // Close menu when clicking links
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Cleanup listeners on transition
    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('scroll', handleScroll);
      document.body.style.overflow = '';
    }, { once: true });
  }

  // Run on load and pages transition
  setupHeader();
  document.addEventListener('astro:page-load', setupHeader);
</script>
