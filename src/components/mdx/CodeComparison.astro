---
interface Props {
  beforeLabel?: string;
  afterLabel?: string;
}
const { beforeLabel = "Incorrecto", afterLabel = "Correcto" } = Astro.props;
---
<div class="my-6 grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
  <!-- Before / Bad -->
  <div class="rounded-2xl border border-red-500/20 bg-red-500/5 overflow-hidden shadow-md flex flex-col">
    <div class="px-4 py-2 bg-red-500/10 border-b border-red-500/20 text-xs font-semibold text-red-400 flex items-center gap-1.5 select-none">
      <span>❌</span> {beforeLabel}
    </div>
    <div class="p-4 overflow-x-auto text-sm leading-relaxed prose-comparison flex-grow">
      <slot name="before" />
    </div>
  </div>

  <!-- After / Good -->
  <div class="rounded-2xl border border-emerald-500/20 bg-emerald-500/5 overflow-hidden shadow-md flex flex-col">
    <div class="px-4 py-2 bg-emerald-500/10 border-b border-emerald-500/20 text-xs font-semibold text-emerald-400 flex items-center gap-1.5 select-none">
      <span>✅</span> {afterLabel}
    </div>
    <div class="p-4 overflow-x-auto text-sm leading-relaxed prose-comparison flex-grow">
      <slot name="after" />
    </div>
  </div>
</div>

<style>
  .prose-comparison :global(pre) {
    margin: 0 !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
  }
</style>
