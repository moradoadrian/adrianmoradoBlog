---
interface Props {
  title?: string;
  command: string;
}
const { title = "terminal", command } = Astro.props;
---
<div class="my-6 rounded-2xl border border-white/10 bg-card-dark overflow-hidden shadow-xl text-left font-mono text-sm max-w-3xl mx-auto">
  <!-- Terminal Header -->
  <div class="flex items-center justify-between px-4 py-3 bg-bg-dark/80 border-b border-white/5 select-none">
    <div class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-[#ff5f56]"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e]"></span>
      <span class="w-3 h-3 rounded-full bg-[#27c93f]"></span>
    </div>
    <span class="text-xs text-text-muted font-sans font-medium">{title}</span>
    <!-- Copy button -->
    <button 
      class="text-text-muted hover:text-white transition-colors duration-200 cursor-pointer flex items-center gap-1 text-xs copy-terminal-btn select-none"
      data-code={command}
      aria-label="Copiar comando"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
      </svg>
      <span class="copy-text">Copiar</span>
    </button>
  </div>
  <!-- Terminal Body -->
  <div class="p-5 overflow-x-auto text-text-muted leading-relaxed select-all">
    <span class="text-accent select-none mr-2">$</span>{command}
  </div>
</div>

<script>
  function setupTerminalCopy() {
    const buttons = document.querySelectorAll('.copy-terminal-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const code = btn.getAttribute('data-code') || '';
        const textSpan = btn.querySelector('.copy-text');
        
        navigator.clipboard.writeText(code).then(() => {
          if (textSpan) {
            textSpan.textContent = '¡Copiado!';
            setTimeout(() => {
              textSpan.textContent = 'Copiar';
            }, 2000);
          }
        });
      });
    });
  }

  setupTerminalCopy();
  document.addEventListener('astro:page-load', setupTerminalCopy);
</script>
