---
import Layout from './Layout.astro';

interface Heading {
  slug: string;
  text: string;
  depth?: number;
}

interface Props {
  title: string;
  description: string;
  lastUpdated: string;
  readingTime: string;
  headings: Heading[];
}

const { title, description, lastUpdated, readingTime, headings } = Astro.props;
---

<Layout title={`${title} | Centro Legal`} description={description}>
  <main class="min-h-screen pt-32 pb-16 px-4 max-w-7xl mx-auto relative overflow-hidden" id="legal-post-root">
    <!-- Glow effect background -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[180px] pointer-events-none"></div>

    <!-- Floating Back to Top Button -->
    <button 
      id="back-to-top" 
      class="fixed bottom-6 right-6 p-3 rounded-full bg-primary hover:bg-primary/80 border border-primary/20 text-white shadow-lg cursor-pointer transform translate-y-24 opacity-0 transition-all duration-300 z-50 hover:shadow-[0_0_15px_rgba(109,94,249,0.5)]" 
      aria-label="Volver arriba"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5">
        <line x1="12" y1="19" x2="12" y2="5"></line>
        <polyline points="5 12 12 5 19 12"></polyline>
      </svg>
    </button>

    <!-- Breadcrumbs Navigation -->
    <nav class="max-w-6xl mx-auto mb-6 text-xs sm:text-sm text-text-muted flex items-center gap-2 select-none" aria-label="Breadcrumb">
      <a href="/" class="hover:text-accent transition-colors duration-200">Inicio</a>
      <span>/</span>
      <a href="/legal" class="hover:text-accent transition-colors duration-200">Legal</a>
      <span>/</span>
      <span class="text-white font-medium truncate max-w-[200px] sm:max-w-xs">{title}</span>
    </nav>

    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 items-start relative z-10">
      
      <!-- Sticky Sidebar: Info & Reading Details -->
      <aside class="hidden lg:flex lg:col-span-3 flex-col gap-6 sticky top-32 h-fit">
        <div class="glass-card p-5 rounded-2xl border border-white/5 bg-card-dark/40 space-y-4">
          <div class="text-xs text-text-muted space-y-3">
            <div>
              <span class="block font-semibold text-white/50 uppercase tracking-wider text-[9px] mb-0.5">Actualizado:</span>
              <span class="text-white/90 font-sans">{lastUpdated}</span>
            </div>
            <div>
              <span class="block font-semibold text-white/50 uppercase tracking-wider text-[9px] mb-0.5">Lectura estimada:</span>
              <span class="text-white/90 font-sans">{readingTime}</span>
            </div>
            <div>
              <span class="block font-semibold text-white/50 uppercase tracking-wider text-[9px] mb-0.5">Jurisdicción:</span>
              <span class="text-white/90 font-sans">Guanajuato, México</span>
            </div>
          </div>
          
          <div class="border-t border-white/5 pt-3">
            <a href="/legal" class="inline-flex items-center gap-1.5 text-xs text-accent hover:text-white transition-colors duration-200 font-semibold font-display">
              &larr; Volver al Centro Legal
            </a>
          </div>
        </div>
      </aside>

      <!-- Center: Main Document Container -->
      <div class="lg:col-span-6 space-y-8" id="document-body-wrapper">
        <div class="space-y-4">
          <h1 class="text-3xl sm:text-5xl font-display font-bold text-white tracking-tight leading-tight">
            {title}
          </h1>
          <p class="text-text-muted text-base sm:text-lg font-sans">
            {description}
          </p>
          <div class="border-b border-white/10 pb-4"></div>
        </div>

        <!-- Document Content -->
        <div class="prose max-w-none text-text-muted font-sans text-base sm:text-lg leading-relaxed space-y-6" id="post-content">
          <slot />
        </div>
      </div>

      <!-- Right Sticky Sidebar: Table of Contents -->
      {headings.length > 0 && (
        <aside class="hidden lg:block lg:col-span-3 sticky top-32 h-fit space-y-4" id="article-toc-sidebar">
          <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted border-b border-white/5 pb-2 select-none">En esta página</h4>
          <nav class="space-y-2 text-sm max-h-[70vh] overflow-y-auto pr-2 scrollbar-none" id="toc-container">
            {headings.map((h) => (
              <a 
                href={`#${h.slug}`} 
                class="block text-text-muted hover:text-accent transition-colors duration-200 py-1 font-medium leading-snug border-l border-white/5 pl-3 toc-link"
                style={`padding-left: ${((h.depth || 2) - 1) * 8 + 8}px`}
              >
                {h.text}
              </a>
            ))}
          </nav>
        </aside>
      )}
    </div>
  </main>
</Layout>

<script>
  function setupLegalPage() {
    const backToTopBtn = document.getElementById('back-to-top');
    const links = document.querySelectorAll('.toc-link');
    const headings = document.querySelectorAll('#post-content h2, #post-content h3');

    const handleScroll = () => {
      // Back to top visibility
      if (window.scrollY > 300) {
        backToTopBtn?.classList.remove('translate-y-24', 'opacity-0');
        backToTopBtn?.classList.add('translate-y-0', 'opacity-100');
      } else {
        backToTopBtn?.classList.remove('translate-y-0', 'opacity-100');
        backToTopBtn?.classList.add('translate-y-24', 'opacity-0');
      }

      // Highlight active heading in TOC
      let currentActiveId = '';
      headings.forEach((heading) => {
        const top = heading.getBoundingClientRect().top;
        if (top < 150) {
          currentActiveId = heading.id;
        }
      });

      links.forEach((link) => {
        const href = link.getAttribute('href');
        if (href === `#${currentActiveId}`) {
          link.classList.add('text-accent', 'border-accent');
          link.classList.remove('text-text-muted', 'border-white/5');
        } else {
          link.classList.remove('text-accent', 'border-accent');
          link.classList.add('text-text-muted', 'border-white/5');
        }
      });
    };

    window.addEventListener('scroll', handleScroll);
    handleScroll(); // initial check

    backToTopBtn?.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    // Clean up
    document.addEventListener('astro:before-preparation', () => {
      window.removeEventListener('scroll', handleScroll);
    }, { once: true });
  }

  setupLegalPage();
  document.addEventListener('astro:page-load', setupLegalPage);
</script>

<style is:global>
  #post-content h2 {
    font-family: var(--font-display);
    color: #fff;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    scroll-margin-top: 120px;
    font-size: 1.75rem;
    font-weight: 700;
  }
  #post-content h3 {
    font-family: var(--font-display);
    color: #fff;
    margin-top: 2rem;
    margin-bottom: 1rem;
    scroll-margin-top: 120px;
    font-size: 1.4rem;
    font-weight: 700;
  }
  #post-content p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }
  #post-content a {
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: underline;
  }
  #post-content a:hover {
    color: var(--color-primary);
  }
  #post-content ul {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    list-style-type: disc;
  }
  #post-content li {
    margin-bottom: 0.5rem;
  }
</style>
